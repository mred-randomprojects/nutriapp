{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "rootDir": ".",
    "outDir": "./.tmp/test-dist",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src/components/dailyLogKeyboard.ts",
    "src/components/dailyLogKeyboard.test.ts",
    "src/searchOptionKeyboard.ts",
    "src/searchOptionKeyboard.test.ts",
    "src/tombstones.ts",
    "src/tombstones.test.ts",
    "src/deletedDayLogEntries.ts",
    "src/deletedAppEntities.ts",
    "src/types.ts"
  ]
}
